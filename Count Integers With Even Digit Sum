class Solution(object):
    def countEven(self, num):
        if num==0 or num == 1:
            return 0
        c=0
        for n in range(2,num+1):
            rem=0
            s=0
            while n>0:
                rem=n%10
                s+=rem
                n=n//10
            if s%2==0:
                c+=1
        return c


