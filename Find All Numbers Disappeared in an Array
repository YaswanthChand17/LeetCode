class Solution(object):
    def findDisappearedNumbers(self, nums):
        n=len(nums)
        for i in range(n):
            k=abs(nums[i])-1
            if nums[k]>0:
                nums[k]=-nums[k]
        ans=[]
        for i in range(n):
            if nums[i]> 0:
                ans.append(i+ 1)
        return ans
