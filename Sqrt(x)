class Solution(object):
    def mySqrt(self, x):
        if x<2:
            return x
        a,b= 2,x//2
        while a<=b:
            m=(a+b)//2
            if m*m==x:
                return m
            elif m*m<x:
                a=m+1
            else:
                b=m-1
        return b
