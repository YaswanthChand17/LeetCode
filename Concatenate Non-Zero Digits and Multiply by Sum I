class Solution(object):
    def sumAndMultiply(self, n):
        s=0 
        x=0
        i=1 
        while n>0:
            rem=n%10
            if rem!=0:
                s=s+rem
                x=x+rem*i
                i*=10
                n=n//10
            else:
                n=n//10
        return x*s
